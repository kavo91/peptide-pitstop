# ─────────────────────────────────────────────────────────────────────────────
# Peptide Pitstop — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# 32-byte base64 key for AES-256-GCM field encryption. Generate with:
#   openssl rand -base64 32
# WARNING: if you lose or change this, previously-encrypted fields become unreadable.
PT_FIELD_KEY=

# Secret used to sign session cookies (JWT). Generate with:
#   openssl rand -base64 48
AUTH_SECRET=

# SQLite database location. The Docker setup mounts ./data to /data.
DATABASE_URL=file:/data/peptides.db

# ── Access & sessions ────────────────────────────────────────────────────────
# Set to true when served over HTTPS (the default). Set to false ONLY if you
# access the app over plain http on a trusted LAN, or login cookies won't stick.
COOKIE_SECURE=true

# Optional: minimum password length enforced at /setup (default 12).
# MIN_PASSWORD=12

# Optional: if set, /setup requires ?token=<this> — handy if the app is briefly
# reachable before you've provisioned the owner account.
# SETUP_TOKEN=

# ── Appearance ───────────────────────────────────────────────────────────────
# Optional: label shown next to the app name (e.g. "dev", "staging").
# ENV_LABEL=

# Timezone — set to YOUR zone so local-midnight schedules read correctly.
# e.g. America/New_York, Europe/London, Australia/Brisbane. Defaults to UTC.
TZ=UTC

# ── Integrations (all optional) ──────────────────────────────────────────────
# Home Assistant webhook for push dose reminders.
# HA_WEBHOOK_URL=https://your-home-assistant:8123/api/webhook/peptide_dose_reminder

# Cloudflare Tunnel token (for the optional tunnel sidecar — no open ports).
# CLOUDFLARE_TUNNEL_TOKEN=

# Bearer token the Garmin sync sidecar presents when importing wellness data.
# Generate with: openssl rand -hex 32   (fails closed if unset — sync disabled)
# WELLNESS_IMPORT_TOKEN=

# Garmin Connect credentials (only if using the Garmin wellness sidecar).
# GARMIN_EMAIL=
# GARMIN_PASSWORD=
# GARMIN_SYNC_URL=http://localhost:8080/sync

# Shared secret protecting the scheduled cron endpoints (/api/cron/*).
# CRON_SECRET=

# Optional: token gating the peptide-library enrichment-refresh endpoint.
# ENRICHMENT_REFRESH_TOKEN=
