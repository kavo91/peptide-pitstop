Dockerfile
docker-compose.yml
# DB artifacts — recursive so prisma/*.db, _proddb.db, WAL/SHM never enter the
# build context (a copied prod DB here would otherwise be baked into the image).
**/*.db
**/*.db-wal
**/*.db-shm
**/*.db-journal
# macOS metadata
**/._*
**/.DS_Store
.DS_Store
# Python bytecode
**/__pycache__
**/*.pyc
# GitHub Pages landing + SEO assets (served by Pages, not part of the app image)
/index.html
/CNAME
/.nojekyll
/sitemap.xml
/robots.txt
/*.txt
/docs
# Repo docs (not needed in the runtime image)
/README.md
/CONTRIBUTING.md
/SECURITY.md
/NOTICE.md
/.github
